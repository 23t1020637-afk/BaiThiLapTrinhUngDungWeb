
@model PagedResult<Product>
@{
	Product product = ViewBag.Product;
	List<Product> ListProductSales = ViewBag.ProductSales;
}
	<style>
    .product-img {
        width: 250px;
        height: 250px;
        object-fit: cover; /* Cắt ảnh để vừa khung, không méo */
        object-position: center; /* Canh giữa */
    }
		#imgOverlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.9);
    display: none;
    justify-content: center;
    align-items: center;
    z-index: 9999;
}
#imgOverlay {
    opacity: 0;
    transition: opacity 0.3s ease;
}

#imgOverlay.show {
    display: flex;
    opacity: 1;
}
#imgOverlay img {
    max-width: 90%;
    max-height: 90%;
}
	</style>
<section class="banner-area">
	<div class="container">
		<div class="row fullscreen align-items-center justify-content-start">
			<div class="col-lg-12">
				<div class="active-banner-slider owl-carousel">
					<!-- single-slide -->
					<div class="row single-slide align-items-center d-flex">
						<div class="col-lg-5 col-md-6">
							<div class="banner-content">
								<h1>Product New <br>Panasonic DH-3JP3VK!</h1>
								<p>
									Panasonic DH-3JP3VK là dòng máy nước nóng trực tiếp (không bình chứa) đến từ thương hiệu Panasonic,
									được thiết kế nhỏ gọn, hiện đại, phù hợp với gia đình có nhu cầu sử dụng nước nóng nhanh và ổn định.
								</p>
								<div class="add-bag d-flex align-items-center">
