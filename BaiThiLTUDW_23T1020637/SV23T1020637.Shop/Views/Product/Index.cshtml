@* <div id="imgOverlay">
    <span class="closeBtn">&times;</span>
    <img id="overlayImg" src="" alt="Product Image">
</div> *@
<script>
document.addEventListener("DOMContentLoaded", function() {
    const overlay = document.getElementById('imgOverlay');
    const overlayImg = document.getElementById('overlayImg');
    const closeBtn = overlay.querySelector('.closeBtn');

    // Nút đóng
    closeBtn.addEventListener('click', function() {
        overlay.style.display = 'none';
    });

    // Click ngoài ảnh cũng đóng overlay
    overlay.addEventListener('click', function(e) {
        if(e.target === overlay) {
            overlay.style.display = 'none';
        }
    });

    // Hàm mở ảnh
    window.openImage = function(productId) {
        const img = document.getElementById('productImg_' + productId);
        if(!img) return;
        overlayImg.src = img.src; // URL ảnh
        overlay.style.display = 'flex';
    };
});
function updatePrice(min, max) {
    // 1. Cập nhật phần hiển thị (có định dạng dấu phẩy cho đẹp)
    document.getElementById('lower-value-price').innerText = min.toLocaleString('vi-VN');
    document.getElementById('upper-value-price').innerText = max.toLocaleString('vi-VN');

    // 2. QUAN TRỌNG: Cập nhật giá trị vào thẻ input để C# nhận được
    document.getElementById('min-input').value = min;
    document.getElementById('max-input').value = max;
}
</script>
