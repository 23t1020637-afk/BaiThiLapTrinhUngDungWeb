<style>
	.social-info {
    display: inline-flex;
    flex-direction: column; /* icon trên text */
    align-items: center;
    justify-content: center;
    gap: 4px; /* khoảng cách icon và text */
    padding: 6px 12px;
    background: transparent;
    border: none;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    font-size: 14px;
}

.social-info:hover {
    background-color: rgba(0,0,0,0.1);
}
/* overlay full screen */
#imgOverlay {
    display: none; /* ẩn mặc định */
    position: fixed;
    z-index: 9999;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(0,0,0,0.95); /* nền tối gần như full màn hình */
    display: flex;
    justify-content: center; /* căn giữa ngang */
    align-items: center;    /* căn giữa dọc */
}

/* ảnh phóng to full screen, giữ tỷ lệ */
#imgOverlay img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain; /* giữ tỷ lệ */
}

/* nút đóng */
#imgOverlay .closeBtn {
    position: absolute;
    top: 20px;
    right: 35px;
    color: #fff;
    font-size: 50px;
    font-weight: bold;
    cursor: pointer;
    z-index: 10000;
}
</style>
