
@model Customer
<section style="margin-top: 100px; margin-bottom: 150px;">
    <div class="container py-5">
        <div class="row">
            <!-- Avatar và thông tin cơ bản -->
            <div class="col-lg-4">
                <div class="card mb-4">
                    <div class="card-body text-center">
                        <img src="~/images/employees/nophoto.png" alt="avatar"
                             class="rounded-circle img-fluid" style="width: 150px;">
                            <h5 class="my-3">@Model.CustomerName</h5>
                            <p class="text-muted mb-1">@Model.ContactName</p>
                            <p class="text-muted mb-4">@Model.Address</p>
                            <p class="text-muted mb-4">@Model.Province</p>
                        </div>
                    </div>
                </div>

                <!-- Form cập nhật thông tin -->
                <div class="col-lg-8">
                    <div class="card mb-4">
                        <div class="card-body">
                        @* string email, string oldPassword  ,string NewPassword, string ConfirmPassword *@
                            <form id="changePasswordForm" method="post" asp-action="ChangePasswordCustomers">
                                <input type="hidden" asp-for="@Model.Email" />
                            <div asp-validation-summary="All" class="text-danger"></div>
                            <div class="row mb-3">
                                <div class="col-sm-4">
                                    <label class="form-label">Mật khẩu Cũ </label>
                                </div>
                                <div class="col-sm-8">
                                    <input type="password" id="NewPassword" name="oldPassword" class="form-control" required />
                                </div>
                            </div>
                                <div class="row mb-3">
                                    <div class="col-sm-4">
                                        <label class="form-label">Mật khẩu mới</label>
                                    </div>
                                    <div class="col-sm-8">
                                    <input type="password" id="NewPassword" name="NewPassword" class="form-control" required />
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-sm-4">
                                        <label class="form-label">Xác nhận mật khẩu</label>
                                    </div>
                                    <div class="col-sm-8">
                                    <input type="password" id="ConfirmPassword" name="ConfirmPassword" class="form-control" required />
                                      
                                </div>
                                </div>

                                <div id="passwordError" class="text-danger mb-3" style="display:none;">
                                    Mật khẩu mới và xác nhận mật khẩu không khớp. Vui lòng nhập lại.
                                </div>
                                <div class="d-flex justify-content-end gap-2">
                                    <a href="~/Account" class="btn btn-secondary">Back</a>
                                    <button type="submit" class="btn btn-warning">Đổi mật khẩu</button>
                                </div>
                            </form>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/6.4.0/mdb.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/6.4.0/mdb.min.js"></script>
