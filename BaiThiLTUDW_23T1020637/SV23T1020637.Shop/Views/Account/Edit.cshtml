@model Customer

<section style="margin-top: 100px; margin-bottom: 150px;">
    <div class="container py-5">
        <div class="row">
            <!-- Avatar và thông tin cơ bản -->
            <div class="col-lg-4">
                <div class="card mb-4">
                    <div class="card-body text-center">
                        <img src="~/images/employees/nophoto.png" alt="avatar"
                             class="rounded-circle img-fluid" style="width: 150px;">
                            <h5 class="my-3">@Model.CustomerName</h5>
                            <p class="text-muted mb-1">@Model.ContactName</p>
                            <p class="text-muted mb-4">@Model.Address</p>
                            <p class="text-muted mb-4">@Model.Province</p>
                        </div>
                    </div>
                </div>

                <!-- Form cập nhật thông tin -->
                <div class="col-lg-8">
                    <div class="card mb-4">
                        <div class="card-body">
                            <form asp-action="UpdateProfile" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" asp-for="@Model.CustomerID" />
                                <input type="hidden" asp-for="@Model.IsLocked" />
                                <div class="row mb-3">
                                    <div class="col-sm-3">
                                        <label for="CustomerName" class="form-label">Full Name</label>
                                    </div>
                                    <div class="col-sm-9">
                                        <input type="text" class="form-control" id="CustomerName"
                                               name="CustomerName" value="@Model.CustomerName" />
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-sm-3">
                                        <label for="CustomerName" class="form-label">Contact Name</label>
                                    </div>
                                    <div class="col-sm-9">
                                        <input type="text" class="form-control" id="ContactName"
                                               name="ContactName" value="@Model.ContactName" />
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-sm-3">
                                        <label for="Email" class="form-label">Email</label>
                                    </div>
                                    <div class="col-sm-9">
                                        <input type="email" class="form-control" id="Email"
                                               name="Email" value="@Model.Email" />
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-sm-3">
                                        <label for="Phone" class="form-label">Phone</label>
                                    </div>
                                    <div class="col-sm-9">
                                        <input type="text" class="form-control" id="Phone"
                                               name="Phone" value="@Model.Phone" />
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-sm-3">
                                        <label for="Address" class="form-label">Address</label>
                                    </div>
                                    <div class="col-sm-9">
                                        <input type="text" class="form-control" id="Address"
                                               name="Address" value="@Model.Address" />
                                    </div>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-sm-3">
                                        <label for="Province" class="form-label">Province</label>
                                    </div>
                                    <div class="col-sm-9">
                                        <select class="form-select"
                                                asp-for="@Model.Province"
                                                asp-items="await SelectListHelper.Provinces()">
                                        </select>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-end gap-2">
                                    <a href="~/Account" class="btn btn-secondary">Back</a>
                                    <button type="submit" class="btn btn-primary">Cập nhật</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/6.4.0/mdb.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/6.4.0/mdb.min.js"></script>
