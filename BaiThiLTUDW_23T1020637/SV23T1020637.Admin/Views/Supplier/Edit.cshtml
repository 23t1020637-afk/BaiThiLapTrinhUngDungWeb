@model Supplier
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Supplier" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-truck me-2"></i>
                    Thông tin nhà cung cấp
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" asp-action="SaveData">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">
                            Tên nhà cung cấp
                            
                                @Converter.RequiredAsterisk()
                           
                        </label>
                        <input type="hidden" asp-for="@Model.SupplierID" />
                        <input type="text"
                               class="form-control"
                               asp-for="@Model.SupplierName"
                               placeholder="Nhập tên nhà cung cấp" autofocus />
                        <span asp-validation-for="SupplierName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            Tên giao dịch
                            (<i class="bi bi-asterisk text-danger" style="font-size: 0.7rem;" title="Bắt buộc nhập"></i>)
                        </label>
                        <input type="text"
                               class="form-control"
                               asp-for="@Model.ContactName"
                               placeholder="Nhập tên giao dịch" />
                        <span asp-validation-for="ContactName" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Điện thoại</label>
                            <input type="tel"
                                   class="form-control"
                                   asp-for="@Model.Phone"
                                   placeholder="Nhập số điện thoại" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                            <input type="email"
                                   class="form-control"
                                   asp-for="@Model.Email"
                                   placeholder="Nhập email" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <textarea class="form-control"
                                  rows="3"
                                  title"
                                  placeholder="Nhập địa chỉ" asp-for="@Model.Address"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tỉnh / Thành @Converter.RequiredAsterisk();</label>
                        <select class="form-select" asp-for="Province"
                                asp-items="await SelectListHelper.Provinces()">
                            <option value="">-- Chọn tỉnh / thành --</option>
                        </select>
                        <span asp-validation-for="Province" class="text-danger"></span>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
