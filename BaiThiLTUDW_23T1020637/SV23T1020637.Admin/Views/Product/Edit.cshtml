
@using SV23T1020637.BusinessLayers
@model Product
@{
    
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box-seam me-2"></i>
                    Thông tin mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" asp-action="SaveData" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="@Model.ProductID" />
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Tên mặt hàng @Converter.RequiredAsterisk()</label>
                        <div class="col-sm-9">
                            <input type="text"
                                   class="form-control"
                                   asp-for="@Model.ProductName"
                                   placeholder="Nhập tên mặt hàng" autofocus />
                            <span asp-validation-for="ProductName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Loại hàng @Converter.RequiredAsterisk()</label>
                        <div class="col-sm-3">
                            <select class="form-select"
                                    asp-for="CategoryID"
                                    asp-items="await SelectListHelper.Categories()">
                            </select>
                            <span asp-validation-for="CategoryID" class="text-danger"></span>
                        </div>

                        <label class="col-sm-2 col-form-label text-end">Nhà cung cấp @Converter.RequiredAsterisk()</label>
                        <div class="col-sm-4">
                            <select class="form-select"
                                    asp-for="SupplierID"
                                    asp-items="await SelectListHelper.Suppliers()">
                            </select>
                            <span asp-validation-for="SupplierID" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Đơn vị tính @Converter.RequiredAsterisk()</label>
                        <div class="col-sm-3">
                            <input type="text"
                                   class="form-control"
                                   asp-for="@Model.Unit"
                                   placeholder="cái, hộp, kg..." />
                            <span asp-validation-for="Unit" class="text-danger"></span>
                        </div>

                        <label class="col-sm-2 col-form-label text-end">Giá @Converter.RequiredAsterisk()</label>
                        <div class="col-sm-4">
                            <input type="number"
                                   class="form-control money-input"
                                   placeholder="Giá bán"
                                   asp-for="@Model.Price"
                                   min="0" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input"
                                       type="checkbox"
                                       id="IsSelling"
                                       asp-for="@Model.IsSelling" />
                                <label class="form-check-label" for="IsSelling">
                                    Đang bán
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh</label>
                        <div class="col-sm-9">
                            <div class="mt-2">
                                <input type="hidden" asp-for="Photo" />
                                <img id="imgPreview"
                                     src="@(string.IsNullOrWhiteSpace(Model.Photo)
                                                                                                                              ? Url.Content("~/images/products/nophoto.png")
                                                                                                                              : Url.Content("~/images/products/" + Model.Photo))"
                                     class="img-thumbnail img"
                                     style="max-height:200px;" />
                            </div>

                            <input type="file"
                                   name="uploadPhoto"
                                   class="form-control"
                                   accept="image/*"
                                   onchange="document.getElementById('imgPreview').src = window.URL.createObjectURL(this.files[0])" />

                            <span asp-validation-for="Photo" class="text-danger"></span>
                               </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Mô tả</label>
                        <div class="col-sm-9">
                            <textarea class="form-control"
                                      rows="3"
                                      asp-for="@Model.ProductDescription"
                                      placeholder="Nhập mô tả mặt hàng"></textarea>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>
@{
    @await Html.PartialAsync("ListPhotos", Model.ProductID)
    @await Html.PartialAsync("ListAttributes", Model.ProductID);
    
}
