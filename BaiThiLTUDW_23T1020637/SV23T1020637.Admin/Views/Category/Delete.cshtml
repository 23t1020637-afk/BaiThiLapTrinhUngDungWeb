@model Category

@{
    ViewBag.Title = "Xóa loại hàng";
    bool isUsed = ViewBag.isUsed;
    string? color_card = (ViewBag.isUsed ? "primary" : "danger");
}
@section PageToolBar {
    @if (!ViewBag.isUsed)
    {
        <button type="submit" form="formDelete" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>
            Xóa
        </button>
    }
    <a href="~/Category" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-@color_card card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0 text-@color_card">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Xác nhận xóa nhà cung cấp
                </h5>
            </div>

            <div class="card-body">
                <form id="formDelete" method="post" asp-action="Delete">
                    @Html.AntiForgeryToken()
                    <div class="alert alert-warning d-flex align-items-center">
                        
                        
                        @if (isUsed)
                        {
                            <p class="text-@color_card">
                                <i class="bi bi-info-circle me-2"></i>
                                Loại hàng này liên quan đến sản phẩm khác không thể xóa !
                            </p>
                        }
                        else
                        {
                            <p class="text-@color_card">
                                <i class="bi bi-info-circle me-2"></i>
                                Bạn có chắc chắn muốn xóa loại hàng sau không?
                            </p>
                        }
                       
                    </div>
                    <dl class="row mb-0">
                        <dt class="col-sm-3">Tên loại hàng</dt>
                        <dd class="col-sm-9">@Model.CategoryName</dd>

                        <dt class="col-sm-3">Mô tả</dt>
                        <dd class="col-sm-9">
                            @Model.Description
                        </dd>
                    </dl>
                </form>
            </div>
        </div>
    </div>
</div>
