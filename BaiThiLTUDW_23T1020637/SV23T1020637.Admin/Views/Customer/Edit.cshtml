@model Customer

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>
    <a href="~/Customer" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-people me-2"></i>
                    Thông tin khách hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" asp-action="SaveData">
                    @Html.AntiForgeryToken()

                    <div class="row align-items-end">
                        <input type="hidden" asp-for="CustomerID" />
                        <div class="col-md-5 mb-3">
                            <label class="form-label">Tên khách hàng @Converter.RequiredAsterisk()</label>
                            <input type="text"
                                   class="form-control"
                                   asp-for="@Model.CustomerName"
                                   placeholder="Nhập tên khách hàng" autofocus />
                            <span asp-validation-for="CustomerName" class="text-danger"></span>
                            
                        </div>
                        <div class="col-md-5 mb-3">
                            <label class="form-label">Tên giao dịch @Converter.RequiredAsterisk();</label>
                            <input type="text"
                                   class="form-control"
                                   asp-for="@Model.ContactName"
                                   placeholder="Nhập tên giao dịch" />
                            <span asp-validation-for="ContactName" class="text-danger"></span>
                        </div>
                        <div class="col-md-2 mb-3">
                            <label class="form-label d-block">Trạng thái</label>
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input"
                                       type="checkbox"
                                       id="IsActive"
                                       asp-for="IsLocked" />
                                <label class="form-check-label" for="IsActive">
                                    Đang hoạt động
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-5 mb-3">
                            <label class="form-label">Điện thoại </label>
                            <input type="tel"
                                   class="form-control"
                                   asp-for="@Model.Phone"
                                   placeholder="Nhập số điện thoại" />
                        </div>

                        <div class="col-md-7 mb-3">
                            <label class="form-label">Email @Converter.RequiredAsterisk()</label>
                            <input type="email"
                                   class="form-control"
                                   asp-for="@Model.Email"
                                   placeholder="Nhập email" />
                            <span asp-validation-for="@Model.Email" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <textarea class="form-control"
                                  rows="3"
                                  asp-for="@Model.Address"
                                  placeholder="Nhập địa chỉ"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tỉnh / Thành @Converter.RequiredAsterisk()</label>
                        <select class="form-select" asp-for="Province"
                                asp-items="await SelectListHelper.Provinces()">
                            <option value="An Giang">-- Chọn tỉnh / thành --</option>
                        </select>
                        <span asp-validation-for="Province" class="text-danger"></span>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
